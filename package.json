{
  "name": "gapguard",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "GapGuard — AI agent for trading the off-hours gap on tokenized US stocks (Bitget AI Hackathon S1, Track 3)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "judge": "node scripts/judge.mjs",
    "serve:public": "node scripts/serve-public.mjs",
    "paper:journal": "tsx src/stockPaperJournal.ts",
    "evidence": "tsx scripts/build-evidence.ts",
    "evidence:check": "tsx scripts/build-evidence.ts --check",
    "manifest": "tsx src/submissionManifest.ts",
    "manifest:check": "tsx src/submissionManifest.ts --check",
    "demo": "tsx src/replay.ts",
    "replay:proof": "tsx src/replay.ts",
    "verify-log": "tsx src/verify-log.ts",
    "probe:bitget": "tsx src/bitgetProbe.ts",
    "rwa:check": "tsx src/rwa-market.ts",
    "gate-demo": "tsx src/gate-demo.ts",
    "gate:audit": "tsx src/gateAudit.ts",
    "gate:holdout": "tsx src/gateHoldoutReport.ts",
    "holdout:news": "tsx src/fetchHoldoutNews.ts",
    "news:feed": "tsx src/fetchNewsFeed.ts",
    "holdout:score": "tsx src/holdoutGateScoring.ts",
    "operator": "tsx src/operatorConsole.ts",
    "arena:demo": "tsx src/arena-demo.ts",
    "arena:cockpit": "tsx src/arena-cockpit.ts",
    "arena:keygen": "node scripts/arena-keygen.mjs",
    "readiness:audit": "tsx src/readiness-audit.ts",
    "broker:order": "tsx src/broker-cli.ts",
    "broker:balance": "tsx src/broker-balance.ts",
    "auto:trade": "tsx src/autoTrader.ts --mode live",
    "auto:trade:dryrun": "tsx src/autoTrader.ts --mode dry_run",
    "auto:trade:rearm": "tsx src/autoTrader.ts --mode live --rearm-persistent-kill",
    "playbook:run": "node scripts/playbook-run.mjs",
    "backtest": "tsx src/backtest.ts",
    "alpha:certify": "tsx src/alphaCertification.ts",
    "backtest:news": "tsx src/newsBacktest.ts",
    "backtest:multi": "tsx src/multiBacktest.ts",
    "backtest:fetch:rwa": "node scripts/fetch-rwa-sample.mjs",
    "backtest:fetch": "node scripts/fetch-aaplusdt.mjs",
    "news:fetch": "node scripts/fetch-news.mjs",
    "news:bundle": "esbuild scripts/newsRefreshEntry.ts --bundle --platform=node --format=esm --outfile=dist/news-refresh.mjs",
    "rwa:bundle": "esbuild scripts/rwaRefreshEntry.ts --bundle --platform=node --format=esm --outfile=dist/rwa-refresh.mjs",
    "live:calls": "tsx src/buildLiveCalls.ts",
    "live:bundle": "esbuild scripts/liveCallsEntry.ts --bundle --platform=node --format=esm --outfile=dist/live-calls.mjs",
    "broker:rwa-roundtrip": "tsx src/rwaRoundTrip.ts",
    "microstructure:assess": "tsx src/microstructureCalibration.ts",
    "status": "tsx src/buildStatusReport.ts"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "bitget-client": "^1.1.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
